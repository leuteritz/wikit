# Copy to .env and adjust. All values are optional.

# Display name shown in the header and browser tab.
VITE_WIKI_TITLE=Wikit

# Port the server listens on (bare-metal `npm start`; inside Docker the backend
# always listens on 3000 internally — use HTTP_PORT below to change the public port).
PORT=3000

# Host to bind. 0.0.0.0 = reachable in your LAN (e.g. raspberrypi.local).
HOST=0.0.0.0

# Optional: custom path to the SQLite database file (bare-metal only;
# in Docker the backend uses WIKI_DB=/data/wiki.db inside the container).
# WIKI_DB=./backend/data/wiki.db

# --- Docker / docker-compose -------------------------------------------------
# Public port the nginx frontend is published on (host:80 -> container:80).
HTTP_PORT=80

# Host directory that holds the SQLite database (bind-mounted to /data in the
# backend container). Backup = copy this directory. On the Pi this is typically
# an absolute path; locally the default ./data is fine.
#   Pi:    DATA_DIR=/opt/wikit/data   (run once: sudo chown -R 1000:1000 /opt/wikit/data)
DATA_DIR=./data

# --- Java Analyzer AI summaries (Ollama) ---
# Only needed if you want AI method summaries. Without Ollama the analyzer still
# works; summaries fall back to the parsed Javadoc. Defaults shown below.
# Bare-metal (Ollama on the same host):
# OLLAMA_URL=http://localhost:11434/api/generate
# In Docker, "localhost" is the container — reach Ollama on the host via
# host.docker.internal (the compose file maps it to the host gateway):
# OLLAMA_URL=http://host.docker.internal:11434/api/generate
# Or point at another LAN machine:  OLLAMA_URL=http://192.168.1.50:11434/api/generate
# OLLAMA_MODEL=qwen2.5-coder:3b
# OLLAMA_TIMEOUT_MS=20000
