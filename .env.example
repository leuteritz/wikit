# Copy to .env and adjust. All values are optional.

# Display name shown in the header and browser tab.
VITE_WIKI_TITLE=Wikit

# Port the server listens on (production: npm start).
PORT=3000

# Host to bind. 0.0.0.0 = reachable in your LAN (e.g. raspberrypi.local).
HOST=0.0.0.0

# Optional: custom path to the SQLite database file.
# WIKI_DB=./backend/data/wiki.db
